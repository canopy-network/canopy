    ['c_creator','p_bettor','r_resolver','cl_addr','s_from','w_addr','ft_addr',
     'reg_addr','prop_resolver','dis_addr','cv_voter','rv_voter','tal_addr','fin_addr','sl_addr'].forEach(id=>{
